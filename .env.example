# MedSoft CLOUD API Configuration
# Get these credentials from MedSoft representatives
# Documentation: Specificații Interconectare Cont Online v11

# The API domain provided by MedSoft (e.g., https://api.med-soft.ro)
MEDSOFT_API_URL="https://your-medsoft-domain.med-soft.ro"

# The X-API-KEY header value from MedSoft Cloud
# Found in: MedSoft CLOUD → Setări → Interconectări → Cont Online
MEDSOFT_API_KEY="aaaaa-bbbbbb-cccccccc-dddddd"

# Your client path for API endpoints
MEDSOFT_CLIENT_PATH="your-clinic-path"

# Netopia mobilPay
# Generate base64 on PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("$PWD\sandbox.3A4U-WGBO-WTER-FPDV-FH1V.public.cer"))
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("$PWD\sandbox.3A4U-WGBO-WTER-FPDV-FH1Vprivate.key"))
NETOPIA_MERCHANT_ID="3A4U-WGBO-WTER-FPDV-FH1V"
NETOPIA_PUBLIC_CERT_B64="<base64 encoded .public.cer>"
NETOPIA_PRIVATE_KEY_B64="<base64 encoded .private.key>"
NETOPIA_SANDBOX="true"

# App Environment
NODE_ENV="development"
PUBLIC_APP_URL="http://localhost:5173"

# Sanity CMS
# Project ID is public (used in browser); dataset is "production" for live content.
# Get values from sanity.io/manage → your project → API.
PUBLIC_SANITY_PROJECT_ID="iz2dbpse"
PUBLIC_SANITY_DATASET="production"
PUBLIC_SANITY_API_VERSION="2026-05-03"

# Studio URL is used by Visual Editing to know where the Studio lives.
# In dev: http://localhost:5173/studio
# In preview/prod: same origin as the site, suffixed with /studio
PUBLIC_SANITY_STUDIO_URL="http://localhost:5173/studio"

# Read token used by SvelteKit server to fetch drafts in preview mode.
# Generate at sanity.io/manage → API → Tokens (Viewer permissions).
# NEVER commit the actual value — store only in .env (gitignored) and Vercel env vars.
SANITY_API_READ_TOKEN=""
